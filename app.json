{
  "expo": {
    "name": "AmazingWallet",
    "slug": "AmazingWallet",
    "version": "1.0.0",
    "scheme": "amazingwallet",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zwane.amazingwallet"
    },
    "android": {
      "package": "com.zwane.amazingwallet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "17b78137-f5b0-4685-abf4-00fa701952e1"
      }
    },
    "owner": "zwane27"
  }
}
